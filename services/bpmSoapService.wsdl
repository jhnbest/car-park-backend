      <output message="tns:synchronizeTemplateOutput"/>
    </operation>
  </portType>

  <binding name="BpmBusinessSystemServiceBinding" type="tns:BpmBusinessSystemServicePortType">
    <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
    <operation name="getTemplateFormList">
      <soap:operation soapAction="http://cldz.xiamenair.com.cn/bpm/getTemplateFormList"/>
