      <xsd:element name="getTemplateFormListResponse">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="result" type="xsd:string"/>
          </xsd:sequence>
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="getFormFieldListRequest">
        <xsd:complexType>
          <xsd:sequence>
            <xsd:element name="sysId" type="xsd:string"/>
            <xsd:element name="modelId" type="xsd:string" minOccurs="0"/>
